# Balkanity Platform — environment variables
# Copy to `.env.local` (gitignored) and fill in. NEVER commit real secret values.
# Infrastructure target: Balkanity Supabase ref qyhdogajtmnvxphrslwm ONLY — never Kalvia.

# --- Browser-safe (NEXT_PUBLIC_*): shipped to the client, RLS is the boundary ---
# Publishable/anon-tier key only. Safe to expose; RLS scopes all access.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Trusted base URL for magic-link redirect targets (e.g. https://balkanity.com).
# Used instead of the client-supplied Origin header to build emailRedirectTo
# (WR-04). Falls back to the request Origin only when unset (local dev).
NEXT_PUBLIC_SITE_URL=

# --- Server-only: NEVER prefix with NEXT_PUBLIC_, never reaches the browser ---
# Used only by server-only modules (e.g. platform/supabase/admin.ts).
# The project URL is NOT a secret — it is read from NEXT_PUBLIC_SUPABASE_URL above
# (single source of truth); only the service-role KEY is server-only here.
SUPABASE_SERVICE_ROLE_KEY=
